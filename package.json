{
  "name": "scribe-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.13.x"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc --ignoreDeprecations 6.0 && vite build",
    "build:analyze": "tsc --ignoreDeprecations 6.0 && vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx,js,jsx --cache --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --ext ts,tsx,js,jsx --fix --cache --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest run",
    "deps:clean": "pnpm prune && pnpm install",
    "deps:reset": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm install",
    "typecheck": "tsc --noEmit --ignoreDeprecations 6.0",
    "precheck": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "set-env": "node scripts/set-env.ts"
  },
  "dependencies": {
    "@auth0/auth0-react": "2.16.1",
    "@microsoft/applicationinsights-web": "^3.3.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "@tanstack/react-query": "^5.84.1",
    "@tanstack/react-router": "1.168.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.508.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "^3.24.4",
    "zustand": "^4.5.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/postcss": "^4.1.6",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "^20.17.45",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.21",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "^9.0.11",
    "jsdom": "^26.1.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rollup-plugin-visualizer": "7.0.1",
    "tailwindcss": "^4.1.6",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --cache --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{jsx,mjs}": [
      "eslint --fix --cache --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{cjs,js}": [
      "prettier --write"
    ],
    "*.{json,css,md,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "lodash": ">=4.18.0"
    }
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
